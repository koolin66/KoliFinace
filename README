
================Это ветка finance_v1===============


    //зачисление - "income"
      трата - "expense"

	//доходы
	зарплата - "salary"
	подарок - "gift"

	//расходы
	еда - "food"
	транспорт - "transport"
	здоровье - "health"
	одежда - "clothes"
	другое - "other"




-------------------ENDPOINTS--------------------------
------------------------------------------------------
/transactions           POST - добавить транзу

формат JSON 
{
    "type": "expense",
    "amount": 550.00,
    "category": "Еда",
    "date": "2024-05-08T14:30:00Z",
    "note": "Обед в кафе"
}
------------------------------------------------------

/transactions           GET  - показать все
------------------------------------------------------

/transactions/<id>       GET  - показать одну по id
------------------------------------------------------

/transactions/<id>        DELETE - удалить по id
------------------------------------------------------

/report/balance          GET  - показать баланс на счете
------------------------------------------------------

/report/period           GET  - показать отчет за период

так указываются параметры в url
/report/period?from=2024-01-01&to=2024-12-31
------------------------------------------------------

